// This is your Prisma schema file

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// 模型配置
model ModelConfig {
  id          Int       @id @default(autoincrement())
  name        String
  baseUrl     String    @map("base_url")
  apiKey      String    @map("api_key") @db.Text
  model       String
  temperature Float     @default(0.7)
  maxTokens   Int       @default(2000) @map("max_tokens")
  apiType     ApiType   @default(OPENAI) @map("api_type")
  isDefault   Boolean   @default(false) @map("is_default")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  categories  Category[]
  logs        GenerationLog[]

  @@map("model_configs")
}

enum ApiType {
  OPENAI       // 标准 OpenAI 兼容：POST /v1/chat/completions
  VOLC_ENGINE  // 火山引擎 Responses API：POST /api/v3/responses
}

// 生成日志
model GenerationLog {
  id             Int          @id @default(autoincrement())
  categoryId     Int          @map("category_id")
  category       Category     @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  modelConfigId  Int?         @map("model_config_id")
  modelConfig    ModelConfig? @relation(fields: [modelConfigId], references: [id], onDelete: SetNull)
  status         GenStatus    @default(PENDING)
  generatedCount Int          @default(0) @map("generated_count")
  errorMsg       String?      @db.Text @map("error_msg")
  createdAt      DateTime     @default(now()) @map("created_at")

  @@map("generation_logs")
}

enum GenStatus {
  PENDING
  RUNNING
  SUCCESS
  FAILED
}

// 分类
model Category {
  id              Int           @id @default(autoincrement())
  name            String
  code            String        @unique
  template        String?       @db.Text
  isScheduled     Boolean       @default(false) @map("is_scheduled")
  cronExpression  String?       @map("cron_expression")
  tags            Json          @default("[]")
  modelConfigId   Int?          @map("model_config_id")
  modelConfig     ModelConfig?  @relation(fields: [modelConfigId], references: [id], onDelete: SetNull)
  order           Int           @default(0)
  isActive        Boolean       @default(true) @map("is_active")
  createdAt       DateTime      @default(now()) @map("created_at")
  updatedAt       DateTime      @updatedAt @map("updated_at")
  cards           Card[]
  logs            GenerationLog[]

  @@map("categories")
}

// 知识卡片
model Card {
  id             Int          @id @default(autoincrement())
  categoryId     Int          @map("category_id")
  category       Category     @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  content        String       @db.Text
  author         String?
  source         String?
  tags           Json         @default("[]")
  likesCount     Int          @default(0) @map("likes_count")
  favoritesCount Int          @default(0) @map("favorites_count")
  status         CardStatus   @default(PUBLISHED)
  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")
  favoritedBy    FavoriteCard[]

  @@map("cards")
}

enum CardStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

// 用户
model User {
  id           Int      @id @default(autoincrement())
  phone        String?  @unique
  email        String?  @unique
  passwordHash String?  @map("password_hash")
  isSubscribed Boolean  @default(false) @map("is_subscribed")
  role         UserRole @default(USER)
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  favorites FavoriteFolder[]
  feedbacks Feedback[]
  settings  UserSettings?

  @@map("users")
}

enum UserRole {
  USER
  ADMIN
}

// 收藏夹
model FavoriteFolder {
  id        Int      @id @default(autoincrement())
  userId    Int      @map("user_id")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name      String
  color     String
  order     Int      @default(0)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  cards FavoriteCard[]

  @@map("favorite_folders")
}

// 收藏夹与卡片的关联
model FavoriteCard {
  folderId  Int            @map("folder_id")
  folder    FavoriteFolder @relation(fields: [folderId], references: [id], onDelete: Cascade)
  cardId    Int            @map("card_id")
  card      Card           @relation(fields: [cardId], references: [id], onDelete: Cascade)
  createdAt DateTime       @default(now()) @map("created_at")

  @@id([folderId, cardId])
  @@map("favorite_cards")
}

// 用户设置（MySQL 不支持数组，用 JSON 存储）
model UserSettings {
  id                 Int      @id @default(autoincrement())
  userId             Int      @unique @map("user_id")
  user               User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  selectedCategories Json     @default("[]") @map("selected_categories")
  categoryOrder      Json     @default("[]") @map("category_order")
  theme              String   @default("system")
  updatedAt          DateTime @updatedAt @map("updated_at")

  @@map("user_settings")
}

// 意见反馈
model Feedback {
  id        Int            @id @default(autoincrement())
  userId    Int?           @map("user_id")
  user      User?          @relation(fields: [userId], references: [id], onDelete: SetNull)
  content   String         @db.Text
  status    FeedbackStatus @default(PENDING)
  createdAt DateTime       @default(now()) @map("created_at")

  @@map("feedbacks")
}

enum FeedbackStatus {
  PENDING
  REVIEWED
  RESOLVED
}

// 标签
model Tag {
  id    Int    @id @default(autoincrement())
  name  String @unique

  @@map("tags")
}

// 卡片曝光记录（用于「未看优先」无限流）
model CardImpression {
  id        BigInt   @id @default(autoincrement())
  visitorId String   @map("visitor_id") @db.VarChar(64)
  cardId    Int      @map("card_id")
  seenAt    DateTime @default(now()) @map("seen_at")

  @@unique([visitorId, cardId])
  @@index([visitorId])
  @@index([visitorId, seenAt])
  @@map("card_impressions")
}

