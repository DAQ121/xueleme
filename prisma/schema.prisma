generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model card_impressions {
  id         BigInt   @id @default(autoincrement())
  visitor_id String   @db.VarChar(64)
  card_id    Int
  seen_at    DateTime @default(now())

  @@unique([visitor_id, card_id])
  @@index([visitor_id])
  @@index([visitor_id, seen_at])
}

model cards {
  id              Int               @id @default(autoincrement())
  category_id     Int
  title           String?           @db.VarChar(200)
  content         String            @db.Text
  author          String?
  source          String?
  tags            Json
  likes_count     Int               @default(0)
  favorites_count Int               @default(0)
  status          cards_status      @default(PUBLISHED)
  source_type     cards_source_type @default(MANUAL)
  created_at      DateTime          @default(now())
  updated_at      DateTime
  categories      categories        @relation(fields: [category_id], references: [id], onDelete: Cascade)
  favorite_cards  favorite_cards[]

  @@index([category_id], map: "cards_category_id_fkey")
}

model categories {
  id              Int               @id @default(autoincrement())
  name            String
  code            String            @unique
  template        String?           @db.Text
  is_scheduled    Boolean           @default(false)
  cron_expression String?
  order           Int               @default(0)
  is_active       Boolean           @default(true)
  created_at      DateTime          @default(now())
  updated_at      DateTime
  tags            Json              @default(dbgenerated("(json_array())"))
  model_config_id Int?
  cards           cards[]
  model_configs   model_configs?    @relation(fields: [model_config_id], references: [id])
  generation_logs generation_logs[]

  @@index([model_config_id], map: "categories_model_config_id_fkey")
}

model favorite_cards {
  folder_id        Int
  card_id          Int
  created_at       DateTime         @default(now())
  cards            cards            @relation(fields: [card_id], references: [id], onDelete: Cascade)
  favorite_folders favorite_folders @relation(fields: [folder_id], references: [id], onDelete: Cascade)

  @@id([folder_id, card_id])
  @@index([card_id], map: "favorite_cards_card_id_fkey")
}

model favorite_folders {
  id             Int              @id @default(autoincrement())
  user_id        Int
  name           String
  color          String
  order          Int              @default(0)
  created_at     DateTime         @default(now())
  updated_at     DateTime
  favorite_cards favorite_cards[]
  users          users            @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id], map: "favorite_folders_user_id_fkey")
}

model feedbacks {
  id         Int              @id @default(autoincrement())
  user_id    Int?
  content    String           @db.Text
  status     feedbacks_status @default(PENDING)
  created_at DateTime         @default(now())
  users      users?           @relation(fields: [user_id], references: [id])

  @@index([user_id], map: "feedbacks_user_id_fkey")
}

model generation_logs {
  id              Int                    @id @default(autoincrement())
  category_id     Int
  model_config_id Int?
  status          generation_logs_status @default(PENDING)
  generated_count Int                    @default(0)
  error_msg       String?                @db.Text
  created_at      DateTime               @default(now())
  categories      categories             @relation(fields: [category_id], references: [id], onDelete: Cascade)
  model_configs   model_configs?         @relation(fields: [model_config_id], references: [id])

  @@index([category_id], map: "generation_logs_category_id_fkey")
  @@index([model_config_id], map: "generation_logs_model_config_id_fkey")
}

model model_configs {
  id              Int                    @id @default(autoincrement())
  name            String
  base_url        String
  api_key         String                 @db.Text
  model           String
  temperature     Float                  @default(0.7)
  max_tokens      Int                    @default(2000)
  is_default      Boolean                @default(false)
  created_at      DateTime               @default(now())
  updated_at      DateTime
  api_type        model_configs_api_type @default(OPENAI)
  categories      categories[]
  generation_logs generation_logs[]
}

model tags {
  id   Int    @id @default(autoincrement())
  name String @unique
}

model user_settings {
  id                  Int      @id @default(autoincrement())
  user_id             Int      @unique
  selected_categories Json
  category_order      Json
  theme               String   @default("system")
  updated_at          DateTime
  users               users    @relation(fields: [user_id], references: [id], onDelete: Cascade)
}

model users {
  id               Int                @id @default(autoincrement())
  phone            String?            @unique
  email            String?            @unique
  password_hash    String?
  is_subscribed    Boolean            @default(false)
  role             users_role         @default(USER)
  created_at       DateTime           @default(now())
  updated_at       DateTime
  favorite_folders favorite_folders[]
  feedbacks        feedbacks[]
  user_settings    user_settings?
}

enum generation_logs_status {
  PENDING
  RUNNING
  SUCCESS
  FAILED
}

enum feedbacks_status {
  PENDING
  REVIEWED
  RESOLVED
}

enum users_role {
  USER
  ADMIN
}

enum cards_status {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum cards_source_type {
  AI_GENERATED
  MANUAL
}

enum model_configs_api_type {
  OPENAI
  VOLC_ENGINE
}
